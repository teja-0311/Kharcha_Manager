# Copy this file to .env.local and fill in your values
# Never commit .env.local to version control

# MongoDB connection string
# For local development: mongodb://localhost:27017/expense-tracker
# For Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/expense-tracker?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://user123:user123@lostfound.mldxg8n.mongodb.net/?appName=lostfound

# Optional: override database name (defaults to expense-tracker)
MONGODB_DB=expense-tracker

# Users database name (defaults to expenses-user)
MONGODB_USERS_DB=expenses-user

# JWT secret used to sign auth cookies
# Use a long random value (e.g., openssl rand -hex 32)
JWT_SECRET=change-me
